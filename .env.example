# ═══════════════════════════════════════════════════════════════════════════════
# mafia-irl — przykładowy plik .env
# Skopiuj jako `.env` w KORZENIU repozytorium.
# Serwer Express ładuje ../../.env z apps/server — nie musisz duplikować.
# Next.js czyta NEXT_PUBLIC_* z apps/web/.env.local (dev) lub Docker env (prod).
# ═══════════════════════════════════════════════════════════════════════════════

# ── PocketBase ─────────────────────────────────────────────────────────────────
# DEV: PocketBase działa lokalnie
POCKETBASE_URL=http://127.0.0.1:8090
# PROD: wewnętrzna sieć Docker (nazwa kontenera/usługi EasyPanel)
# POCKETBASE_URL=http://pocketbase:8090

# Przeglądarka łączy się bezpośrednio z PocketBase (musi być publiczny URL)
NEXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090
# PROD:
# NEXT_PUBLIC_POCKETBASE_URL=https://pb.mafia-irl.profitway.pl

# ── Express + Socket.io ────────────────────────────────────────────────────────
SERVER_PORT=3002

# Lista origins dozwolonych w CORS (po przecinku)
# DEV: localhost
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
# PROD:
# CORS_ORIGIN=https://mafia-irl.profitway.pl

# URL serwera Socket.io widoczny z przeglądarki
NEXT_PUBLIC_SOCKET_URL=http://localhost:3002
# PROD:
# NEXT_PUBLIC_SOCKET_URL=https://ws.mafia-irl.profitway.pl

# ── PocketBase admin (konto /_/, NIE konto gracza) ─────────────────────────────
POCKETBASE_ADMIN_EMAIL=
POCKETBASE_ADMIN_PASSWORD=

# ── Uprawnienia gry ────────────────────────────────────────────────────────────
# Kto może klikać „Utwórz pokój" — musi zgadzać się z emailem konta PB
ALLOWED_ROOM_CREATOR_EMAIL=m.cieplak97@gmail.com
NEXT_PUBLIC_ROOM_HOST_EMAIL=m.cieplak97@gmail.com

# ── Ochrona hasłem (dostęp do aplikacji) ──────────────────────────────────────
# Jeśli ustawione — aplikacja wymaga wpisania hasła przed wejściem.
# Zostaw puste, żeby wyłączyć ochronę (np. lokalnie).
ACCESS_PASSWORD=
# PROD: ACCESS_PASSWORD=twoje-tajne-haslo
